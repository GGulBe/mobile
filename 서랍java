package com.example.test;

import android.os.Bundle;
import android.os.SystemClock;
import android.widget.Button;
import android.widget.Chronometer;
import android.widget.DatePicker;
import android.widget.EditText;
import android.widget.TabHost;
import android.widget.TextView;
import android.widget.TimePicker;
import android.widget.Toast;
import androidx.appcompat.app.AppCompatActivity;

public class MainActivity extends AppCompatActivity {
    // UI 요소들을 전역에서 접근 가능하도록 멤버 변수로 선언
    DatePicker dp; TimePicker tp; Chronometer chrono;
    EditText etName, etId, etPhone, etAge;
    TextView tvResult;
    Button btnStart, btnComplete;

    @Override
    protected void onCreate(Bundle savedInstanceState) {
        super.onCreate(savedInstanceState);
        setContentView(R.layout.activity_main); // XML 레이아웃 연결

        // TabHost 초기화
        TabHost tabHost = findViewById(android.R.id.tabhost);
        tabHost.setup();

        // 각 탭에 ID와 내용을 연결하여 구성
        TabHost.TabSpec ts1 = tabHost.newTabSpec("T1").setIndicator("예약").setContent(R.id.tab1);
        tabHost.addTab(ts1);
        TabHost.TabSpec ts2 = tabHost.newTabSpec("T2").setIndicator("정보").setContent(R.id.tab2);
        tabHost.addTab(ts2);
        TabHost.TabSpec ts3 = tabHost.newTabSpec("T3").setIndicator("결과").setContent(R.id.tab3);
        tabHost.addTab(ts3);

        // XML의 뷰 요소들을 자바 객체와 연결 (findView)
        dp = findViewById(R.id.datePicker); tp = findViewById(R.id.timePicker);
        chrono = findViewById(R.id.chronometer);
        etName = findViewById(R.id.editName); etId = findViewById(R.id.editId);
        etPhone = findViewById(R.id.editPhone); etAge = findViewById(R.id.editAge);
        btnStart = findViewById(R.id.btnStart);
        btnComplete = findViewById(R.id.btnComplete);
        tvResult = findViewById(R.id.txtResult);

        // [예약 시작 버튼]: 크로노미터(타이머)를 0부터 시작
        btnStart.setOnClickListener(v -> {
            chrono.setBase(SystemClock.elapsedRealtime()); // 시작 시간 초기화
            chrono.start(); // 타이머 가동
        });

        // [예약 완료 버튼]: 입력을 마무리하고 결과를 결과창으로 전달
        btnComplete.setOnClickListener(v -> {
            chrono.stop(); // 예약 완료 시 타이머 즉시 정지
            Toast.makeText(getApplicationContext(), "예약이 완료되었습니다!", Toast.LENGTH_SHORT).show();

            // 사용자가 입력한 데이터와 선택한 시간 정보를 문자열로 조합
            String res = "이름: " + etName.getText() + "\n학번: " + etId.getText() +
                    "\n전화번호: " + etPhone.getText() + "\n나이: " + etAge.getText() +
                    "\n예약일: " + dp.getYear() + "년 " + (dp.getMonth()+1) + "월 " + dp.getDayOfMonth() + "일" +
                    "\n예약 시간: " + tp.getHour() + "시 " + tp.getMinute() + "분" +
                    "\n소요 시간: " + chrono.getText(); // 정지된 시점의 타이머 시간 저장

            // 결과창(TextView)에 최종 데이터 출력
            tvResult.setText(res);
        });
    }
}
