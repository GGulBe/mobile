<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp">

    <TextView
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:text="원하는 옵션을 선택하세요"
    android:textSize="20sp" />

    <EditText
    android:id="@+id/editInput"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:hint="여기에 메시지를 입력하세요"
    android:inputType="text" />

    <RadioGroup
    android:id="@+id/radioGroup"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginTop="10dp">

    <RadioButton
        android:id="@+id/radioRed"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="배경색 빨강" />

    <RadioButton
        android:id="@+id/radioBlue"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="배경색 파랑" />
</RadioGroup>

    <Button
        android:id="@+id/btnAction"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="설정 적용 및 초기화" />

    <ImageView
        android:id="@+id/imgResult"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="center_vertical"
        android:src="@drawable/color_splash"
        android:visibility="invisible" />
</LinearLayout>






package com.example.callandram;

import android.graphics.Color;
import android.os.Bundle;
import android.view.View;
import android.widget.Button;
import android.widget.EditText;
import android.widget.ImageView;
import android.widget.RadioGroup;
import android.widget.Toast;

import androidx.appcompat.app.AppCompatActivity;

public class MainActivity extends AppCompatActivity {

    // 위젯 변수 선언
    EditText editInput;
    RadioGroup radioGroup;
    Button btnAction;
    ImageView imgResult;

    @Override
    protected void onCreate(Bundle savedInstanceState) {
        super.onCreate(savedInstanceState);
        setContentView(R.layout.activity_main); // XML 레이아웃 연결

        // 위젯 찾기
        editInput = findViewById(R.id.editInput);
        radioGroup = findViewById(R.id.radioGroup);
        btnAction = findViewById(R.id.btnAction);
        imgResult = findViewById(R.id.imgResult);

        // 버튼 클릭 콜백을 람다식으로 구현
        btnAction.setOnClickListener(v -> {
            String text = editInput.getText().toString(); // 입력값 가져오기 [cite: 58, 1070]

            if (text.isEmpty()) {
                // 토스트 메시지 출력
                Toast.makeText(this, "내용을 입력하세요", Toast.LENGTH_SHORT).show();
                return;
            }

            // 라디오 버튼 선택 결과 확인
            int checkedId = radioGroup.getCheckedRadioButtonId();

            if (checkedId == R.id.radioRed) {
                editInput.setBackgroundColor(Color.RED); // 배경색 변경
                imgResult.setVisibility(View.VISIBLE); // 이미지 보이기
            } else if (checkedId == R.id.radioBlue) {
                editInput.setBackgroundColor(Color.BLUE);
                imgResult.setVisibility(View.VISIBLE);
            } else {
                Toast.makeText(this, "옵션을 선택하세요", Toast.LENGTH_SHORT).show();
            }

            // clearCheck() 사용 특정 작업 완료 후 상태를 초기화할 때 유용함
            radioGroup.clearCheck();

            // 입력창 초기화
            editInput.setText("");
            Toast.makeText(this, "적용 및 초기화 완료!", Toast.LENGTH_SHORT).show();
        });
    }
}
